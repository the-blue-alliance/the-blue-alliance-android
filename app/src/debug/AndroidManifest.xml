<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Debug builds talk to the local dev backend (http://10.0.2.2:8080) and the
        Firebase Auth emulator (10.0.2.2:9099). 10.0.0.0/8 is a local network, which
        targetSdk 37 (Android 17) blocks by default. Declare the runtime permission
        here so a debug build can be granted LAN access; release builds (public TBA
        API over the internet) never need it. Grant it on the device/emulator with:
            adb shell pm grant <debug-package> android.permission.ACCESS_LOCAL_NETWORK
    -->
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />

    <!-- The debug res/xml/network_security_config.xml shadows the main one to
         permit cleartext to the local dev server. -->
    <application>

        <meta-data android:name="firebase_crashlytics_collection_enabled" android:value="false" />
        <meta-data android:name="firebase_crashlytics_auto_collection_enabled" android:value="false" />
        <meta-data android:name="firebase_analytics_collection_enabled" android:value="false" />

        <activity
            android:name=".widget.PinWidgetActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".widget.ReconfigureWidgetsActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".widget.ResizeWidgetsActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".widget.RemoveWidgetsActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <activity
            android:name=".widget.MockWidgetActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <receiver
            android:name=".widget.PinWidgetReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.thebluealliance.android.widget.WIDGET_PINNED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
